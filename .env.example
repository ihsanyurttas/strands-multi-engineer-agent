# =============================================================================
# strands-multi-engineer-agent — environment variable template
# Copy this file to .env and fill in real values.
# Never commit .env to version control.
# =============================================================================

# ---------------------------------------------------------------------------
# Provider selection
# ---------------------------------------------------------------------------
# Which provider to use by default: anthropic | openai | ollama
DEFAULT_PROVIDER=anthropic

# ---------------------------------------------------------------------------
# Anthropic
# ---------------------------------------------------------------------------
ANTHROPIC_API_KEY=your-anthropic-api-key-here
ANTHROPIC_MODEL=claude-sonnet-4-6
ANTHROPIC_MAX_TOKENS=4096

# ---------------------------------------------------------------------------
# OpenAI
# ---------------------------------------------------------------------------
OPENAI_API_KEY=your-openai-api-key-here
OPENAI_MODEL=gpt-4o

# ---------------------------------------------------------------------------
# Ollama  (container-friendly defaults shown)
# When running via Docker Compose, set OLLAMA_BASE_URL to the service name.
# When running natively, use http://localhost:11434
# ---------------------------------------------------------------------------
OLLAMA_BASE_URL=http://ollama:11434
OLLAMA_MODEL=llama3.2

# ---------------------------------------------------------------------------
# Agent runtime behaviour
# ---------------------------------------------------------------------------
# Execution mode: local | docker | kubernetes
AGENT_RUNTIME=local

# Workflow prompt mode: minimal | standard
# minimal  — short structured prompts, relies on conversation history (default, low cost)
# standard — full context re-injected per phase (higher cost, richer output)
WORKFLOW_MODE=minimal

# Logging level: DEBUG | INFO | WARNING | ERROR
LOG_LEVEL=INFO

# Maximum tool-use iterations per workflow run
MAX_ITERATIONS=10

# Directory where structured run results are written
RESULTS_DIR=eval/results

# ---------------------------------------------------------------------------
# Optional: override sample repo path (defaults to ./sample_repos)
# ---------------------------------------------------------------------------
# SAMPLE_REPO_PATH=./sample_repos
